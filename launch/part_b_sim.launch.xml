<launch>
  <!-- Load your Part B params -->
  <arg name="params_file" default="$(find-pkg-share final_challenge)/config/part_b_params.yaml"/>

  <!-- ===== NAVIGATION (SIMULATION) ===== -->
  <node pkg="localization" exec="particle_filter" name="particle_filter" output="screen">
    <!-- Point to the SIMULATOR config -->
    <param from="$(find-pkg-share path_planning)/config/sim/pf_config.yaml"/>
  </node>

  <node pkg="path_planning" exec="trajectory_planner" name="trajectory_planner" output="screen">
    <!-- Point to the SIMULATOR config -->
    <param from="$(find-pkg-share path_planning)/config/sim/pf_sim_config.yaml"/>
  </node>

  <node pkg="path_planning" exec="trajectory_follower" name="trajectory_follower" output="screen">
    <!-- Point to the SIMULATOR config -->
    <param from="$(find-pkg-share path_planning)/config/sim/pf_sim_config.yaml"/>
    <!-- Same mux mapping for state machine! -->
    <param name="drive_topic" value="/drive/nav"/>
  </node>

  <!-- Safety Controller -->
  <node pkg="safety_controller" exec="safety_controller" name="safety_controller" output="screen"/>

  <!-- ===== VISUAL SERVOING ===== -->
  <node pkg="visual_servoing" exec="homography_transformer" name="homography_transformer" output="screen"/>

  <node pkg="visual_servoing" exec="parking_controller" name="parking_controller" output="screen">
    <!-- Same mux mapping for state machine! -->
    <param name="drive_topic" value="/drive/park"/>
  </node>

  <!-- ===== FINAL CHALLENGE MACHINE ===== -->
  <node pkg="final_challenge" exec="yolo_detector" name="yolo_detector" output="screen">
    <param from="$(var params_file)"/>
  </node>

  <node pkg="final_challenge" exec="state_machine" name="part_b_state_machine" output="screen">
    <param from="$(var params_file)"/>
  </node>
  
  <node pkg="final_challenge" exec="image_saver" name="image_saver" output="screen">
    <param from="$(var params_file)"/>
  </node>

  <node pkg="final_challenge" exec="shell_point_mock" name="shell_point_mock" output="screen">
    <param from="$(var params_file)"/>
  </node>
</launch>
